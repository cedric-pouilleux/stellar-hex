{
  "name": "@cedric-pouilleux/stellex-js",
  "version": "0.4.0",
  "type": "module",
  "description": "Deterministic, playable celestial body generator for Three.js and Vue 3.",
  "license": "SEE LICENSE IN LICENSE",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cedric-pouilleux/stellex-js.git"
  },
  "homepage": "https://github.com/cedric-pouilleux/stellex-js#readme",
  "bugs": "https://github.com/cedric-pouilleux/stellex-js/issues",
  "workspaces": [
    "docs",
    "playground"
  ],
  "scripts": {
    "build": "vite build -c vite.build.config.ts && vue-tsc -p tsconfig.build.json && node scripts/prepare-dist.mjs",
    "build:js": "vite build -c vite.build.config.ts",
    "build:types": "vue-tsc -p tsconfig.build.json",
    "build:pkg": "node scripts/prepare-dist.mjs",
    "typecheck": "vue-tsc --noEmit -p tsconfig.build.json",
    "test": "npx vitest run",
    "api:update": "npm run build:types && api-extractor run --local --config api/sim.json && api-extractor run --local --config api/core.json && api-extractor run --local --config api/index.json",
    "api:check": "npm run build:types && api-extractor run --config api/sim.json && api-extractor run --config api/core.json && api-extractor run --config api/index.json",
    "publish:dist": "npm publish ./dist",
    "docs:api": "npm run api     -w @cedric-pouilleux/stellex-js-docs",
    "docs:dev": "npm run dev     -w @cedric-pouilleux/stellex-js-docs",
    "docs:build": "npm run build   -w @cedric-pouilleux/stellex-js-docs",
    "docs:preview": "npm run preview -w @cedric-pouilleux/stellex-js-docs",
    "playground:dev": "npm run dev   -w @cedric-pouilleux/stellex-js-playground",
    "playground:build": "npm run build -w @cedric-pouilleux/stellex-js-playground",
    "site:build": "npm run docs:build && npm run playground:build && node scripts/embed-playground.mjs"
  },
  "peerDependencies": {
    "@tresjs/core": "^5.8.0",
    "simplex-noise": "^4.0.0",
    "three": "^0.183.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "@tresjs/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.7",
    "@tresjs/core": "^5.8.0",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "esbuild": "^0.28.0",
    "simplex-noise": "^4.0.0",
    "three": "^0.183.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^3.0.0"
  },
  "dependencies": {
    "three-mesh-bvh": "^0.9.9"
  }
}
