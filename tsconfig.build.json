{
  "extends": "../../../tsconfig.app.json",
  "compilerOptions": {
    "declaration":        true,
    "emitDeclarationOnly": true,
    "declarationMap":     true,
    "noEmit":             false,
    "composite":          false,
    "outDir":             "./dist",
    "rootDir":            ".",
    "types":              ["vite/client"],
    "tsBuildInfoFile":    null
  },
  "include": ["sim.ts", "core.ts", "index.ts", "**/*.ts", "**/*.vue"],
  "exclude": ["**/*.spec.ts", "vite.build.config.ts", "scripts/**", "dist", "node_modules"]
}
